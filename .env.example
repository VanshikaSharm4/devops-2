# ── LLM Provider ────────────────────────────────────────────
# Choose one: anthropic, gemini, azure_openai
LLM_PROVIDER=azure_openai

# Option 1: Anthropic (claude.ai API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: Google Gemini (free tier available at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 3: Azure OpenAI — amsindia deployment (Adobe internal, via Azure AI Foundry)
# Endpoint must end in /openai/v1  (standard OpenAI SDK style, NOT AzureOpenAI client)
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://amsindia.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano

# ── Azure Storage ────────────────────────────────────────────
AZURE_CONNECTION_STRING=yourconnectionstringhere
# AZURE_STORAGE_CONNECTION_STRING is also accepted as an alias.

# ── Splunk ───────────────────────────────────────────────────
# Pipeline data: manually export 3 CSVs to data/splunk_exports/ (Splunk API deferred)
# SPLUNK_USERNAME=your_adobe_email@adobe.com
# SPLUNK_PASSWORD=your_adobe_password

# ── Cloud Manager Git (Features 2–4: risk, compare, correlate) ─
# Switch dropdown to "idfc" in Cloud Manager → Repositories → Access Repo Info
CM_GIT_REPO_URL=https://git.cloudmanager.adobe.com/idfc/idfc/
CM_GIT_USERNAME=vanssharma-adobe-com
CM_GIT_PASSWORD=your_generated_password_here
GIT_LOCAL_DIR=/Users/vanshika/idfc-repo

# ── Cloud Manager API (per tenant) ───────────────────────────
IDFC_TOKEN=
IDFC_KEY=
HDFC_TOKEN=
HDFC_KEY=
APOLLO_TOKEN=
APOLLO_KEY=

ML_SERVICE_URL=http://127.0.0.1:8090
ML_TENANT_ID=idfc

# ── Program Config ───────────────────────────────────────────
PROGRAM_ID=19905
PIPELINE_ID_PROD=2357452
PIPELINE_ID_DEV=47202398

# ── LogSage Post-Failure Assessment (optional) ───────────────
LOGSAGE_TOKEN_LIMIT=22000
LOGSAGE_QUERY_TOKEN_LIMIT=3000
LOGSAGE_SUCCESS_TEMPLATE_COUNT=3
LOGSAGE_CONTEXT_BEFORE=4
LOGSAGE_CONTEXT_AFTER=6
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANKER_TIMEOUT_SEC=30
BGE_RERANKER_RETRIES=2
BM25_INDEX_PATH=data/cache/bm25_index.pkl
